{
  "hosting": {
    "public": "frontend/dist",
    "cleanUrls": true,
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "redirects": [
      {"source": "/Terms", "destination": "/terms", "type": 301},
      {"source": "/Privacy", "destination": "/privacy", "type": 301},
      {"source": "/About", "destination": "/about", "type": 301},
      {"source": "/CookieSettings", "destination": "/cookie-settings", "type": 301},
      {"source": "/fr", "destination": "/french", "type": 301},
      {"source": "/de", "destination": "/german", "type": 301},
      {"source": "/es", "destination": "/spanish", "type": 301},
      {"source": "/ar", "destination": "/arabic", "type": 301},
      {"source": "/zh", "destination": "/chinese", "type": 301},
      {"source": "/pt", "destination": "/portuguese", "type": 301},
      {"source": "/ja", "destination": "/japanese", "type": 301},
      {"source": "/hi", "destination": "/hindi", "type": 301},
      {"source": "/ru", "destination": "/russian", "type": 301},
      {"source": "/tr", "destination": "/turkish", "type": 301},
      {"source": "/vi", "destination": "/vietnamese", "type": 301},
      {"source": "/id", "destination": "/indonesian", "type": 301},
      {"source": "/ha", "destination": "/hausa", "type": 301},
      {"source": "/pa", "destination": "/punjabi", "type": 301},
      {"source": "/te", "destination": "/telugu", "type": 301},
      {"source": "/af", "destination": "/afrikaans", "type": 301},
      {"source": "/bn", "destination": "/bengali", "type": 301},
      {"source": "/pl", "destination": "/polish", "type": 301},
      {"source": "/zu", "destination": "/zulu", "type": 301}
    ],
    "rewrites": [
      {"source": "/routes/**", "run": {"serviceId": "dicta-notes-backend", "region": "us-central1"}},
      {"source": "**", "destination": "/index.html"}
    ],
    "headers": [
      {"source": "**/*.@(js|css)", "headers": [{"key": "Cache-Control", "value": "max-age=31536000"}]},
      {"source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)", "headers": [{"key": "Cache-Control", "value": "max-age=31536000"}]},
      {"source": "**", "headers": [
        {"key": "X-Frame-Options", "value": "SAMEORIGIN"},
        {"key": "X-Content-Type-Options", "value": "nosniff"},
        {"key": "Referrer-Policy", "value": "strict-origin-when-cross-origin"},
        {"key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()"},
        {"key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://apis.google.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com https://*.run.app wss://*.firebaseio.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com; frame-src 'self' https://*.firebaseapp.com https://*.web.app https://accounts.google.com; media-src 'self' https://*.googleapis.com https://*.firebasestorage.app blob:; worker-src 'self';"}
      ]}
    ]
  }
}
