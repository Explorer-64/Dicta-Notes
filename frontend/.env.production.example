# Production environment variables for Dicta-Notes frontend
# Copy to .env.production and fill in real values (or use CI build-time injection)
# NEVER commit .env.production if it contains secrets

# Cloud Run backend URL (replace with your deployed backend URL)
VITE_API_URL=https://dicta-notes-backend-XXXXX-uc.a.run.app
VITE_WS_API_URL=wss://dicta-notes-backend-XXXXX-uc.a.run.app

# Firebase config for web app (from Firebase Console > Project Settings > General)
# Format: JSON object with apiKey, authDomain, projectId, storageBucket, messagingSenderId, appId
VITE_FIREBASE_CONFIG={"apiKey":"YOUR_API_KEY","authDomain":"dicta-notes.firebaseapp.com","projectId":"dicta-notes","storageBucket":"dicta-notes.firebasestorage.app","messagingSenderId":"YOUR_SENDER_ID","appId":"YOUR_APP_ID"}
