# Dicta-Notes Backend - Environment Variables
# Copy to .env and fill in values. NEVER commit .env
# For production, use Google Cloud Secret Manager instead of .env

# Firebase Service Account JSON (stringified)
# Get from Firebase Console > Project Settings > Service Accounts > Generate new key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}

# Firebase config for JWT validation (or use DATABUTTON_EXTENSIONS)
FIREBASE_CONFIG={"projectId":"dicta-notes",...}

# Optional: Override default storage bucket (default: dicta-notes.firebasestorage.app)
# FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# CORS allowed origins (comma-separated, override for production)
# CORS_ALLOWED_ORIGINS=https://dicta-notes.web.app,https://your-domain.com

# Optional API keys (for local dev - use Secret Manager in production)
# GEMINI_API_KEY=
# RESEND_API_KEY=
# OPENAI_API_KEY=
